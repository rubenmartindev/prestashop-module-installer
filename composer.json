{
    "name": "rubenmartindev/prestashop-module-installer",
    "description": "Install and uninstall helpers for PrestaShop modules (hooks, database, tabs, etc.)",
    "keywords": ["prestashop", "modules", "install", "uninstall", "hooks", "database", "tabs"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Rubén Martín",
            "email": "hola@rubenmartin.dev"
        }
    ],
    "require": {
        "php": ">=5.6.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "mikey179/vfsstream": "^1.6",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpunit/phpunit": "^5.7",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "RubenMartinDev\\PrestaShopModuleInstaller\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RubenMartinDev\\PrestaShopModuleInstaller\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "5.6.0"
        },
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "tests": "phpunit --colors=always",
        "phpcs": "phpcs"
    }
}
