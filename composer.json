{
    "name": "rubenmartindev/prestashop-module-installer",
    "description": "Install and uninstall helpers for PrestaShop modules (hooks, database, tabs, etc.)",
    "keywords": ["prestashop", "modules", "install", "uninstall", "hooks", "database", "tabs"],
    "license": "MIT",
    "type": "library",
    "authors": [
      {
        "name": "Rubén Martín",
        "email": "hola@rubenmartin.dev"
      }
    ],
    "require": {
      "php": ">=5.6.0"
    },
    "autoload": {
      "psr-4": {
        "RubenMartinDev\\PrestaShopModuleInstaller\\": "src/"
      }
    },
    "config": {
      "platform": {
          "php": "5.6.0"
      },
      "sort-packages": true
    }
}
